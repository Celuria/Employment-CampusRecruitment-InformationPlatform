# =============================================================================
# Vue 前端 Git 忽略规则
# =============================================================================

# --- 依赖 ---
node_modules/

# --- 构建产物 ---
dist/
dist-ssr/
*.local

# --- 环境变量（保留开发/生产模板时可提交 .env.development / .env.production）---
.env
.env.local
.env.*.local

# --- 日志 ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- 测试与覆盖率 ---
coverage/
*.lcov
.nyc_output/

# --- TypeScript / Vite 缓存 ---
*.tsbuildinfo
.vite/

# --- 编辑器（保留 extensions 推荐配置）---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- 操作系统 ---
.DS_Store
Thumbs.db
